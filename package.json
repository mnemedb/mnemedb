{
  "name": "mneme",
  "private": true,
  "version": "0.0.0",
  "description": "Agent-native database platform on Base — own Postgres, schema-per-project, wallet-auth, MCP-native.",
  "workspaces": [
    "gateway",
    "sdk",
    "mcp",
    "cli",
    "dashboard"
  ],
  "scripts": {
    "dev:gateway":   "bun --filter mneme-gateway dev",
    "dev:dashboard": "bun --filter mneme-dashboard dev",
    "dev:cli":       "bun --filter mneme-cli dev",
    "build:sdk":     "bun --filter mneme-sdk build",
    "build:mcp":     "bun --filter mneme-mcp build",
    "build:cli":     "bun --filter mneme-cli build",
    "smoke":         "bun run scripts/smoke.ts",
    "typecheck":     "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "viem": "^2.21.0",
    "mneme-sdk": "workspace:*"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@clawnch/clawncher-sdk": "^0.3.4"
  }
}
