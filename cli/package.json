{
  "name": "mneme-cli",
  "version": "0.2.0",
  "description": "Terminal client for Mneme — agent-native Postgres on Base. Text-to-SQL, free-form chat, and live Base ecosystem data (gas / price / TVL / trending). One key, one prompt.",
  "type": "module",
  "bin": {
    "mneme": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build":     "tsup src/index.ts --format esm --clean --target node20 --shims",
    "dev":       "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mneme", "cli", "postgres", "agent", "text-to-sql", "base", "wallet",
    "pgvector", "chat", "claude", "defi", "dexscreener", "tvl", "gas"
  ],
  "license": "MIT",
  "homepage": "https://mnemedb.dev",
  "repository": {
    "type": "git",
    "url":  "https://github.com/mnemedb/mnemedb.git",
    "directory": "cli"
  },
  "author": "mnemedb",
  "dependencies": {
    "mneme-sdk": "^0.5.0",
    "chalk":     "^5.3.0",
    "viem":      "^2.21.0"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
