PORT=8787

# --- Our Postgres (pgvector required; Neon free tier is enough for MVP) ---
DATABASE_URL=postgres://user:pass@host:5432/mneme

# --- Secret used to sign gateway-issued session JWTs (HS256) ---
# Generate: openssl rand -hex 32   (or any cryptographically random 64-char hex)
GATEWAY_JWT_SECRET=

# --- EIP-712 domain (must match SDK + dashboard) ---
MNEME_DOMAIN_NAME=Mneme
MNEME_DOMAIN_VERSION=1
CHAIN_ID=8453

# --- Base RPC URL (for ERC-1271 / 6492 smart-wallet sig verification) ---
# Default public endpoint is rate-limited; switch to Alchemy/Quicknode for prod.
BASE_RPC_URL=https://mainnet.base.org

# --- Replay window for per-request wallet sigs (seconds) ---
SIG_WINDOW_SECONDS=60
