{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun install && bun --filter mneme-dashboard build",
  "outputDirectory": "dashboard/dist",
  "installCommand": "bun install",
  "framework": null,
  "rewrites": [
    { "source": "/m/(.*)", "destination": "/m/index.html" }
  ]
}
