{
  "name": "@mneme/mcp",
  "version": "0.0.0",
  "description": "MCP server for Mneme — let Claude/Cursor/Cline use your agent DB as tools.",
  "type": "module",
  "bin": {
    "mneme-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mneme/sdk": "workspace:*",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
